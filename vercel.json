{
    "version": 2,
    "builds": [
      {
        "src": "src/main.ts",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "src/main.ts",
        "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
      }
    ],
    "crons": [
      {
        "path": "/capital/cierre-cron",
        "schedule": "0 2 * * *"
      },
      {
        "path": "/patrimonio/snapshot-cron",
        "schedule": "30 2 * * *"
      }
    ]
  }
  